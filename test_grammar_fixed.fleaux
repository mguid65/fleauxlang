// Test file showcasing the fixed grammar with left-associative chaining
// The new grammar supports complex pipelines without requiring extra parentheses

import Std;

// Simple pipeline
let Add2(x: Number): Number = (x, 2) -> Std.Add;

// Chained pipelines - now works without extra parentheses!
let AddThenMultiply(x: Number, y: Number, z: Number): Number = (x, y) -> Std.Add -> Std.Multiply;

// Multiple parameters
let MultiplyNumbers(x: Number, y: Number): Number = (x, y) -> Std.Multiply;

// Comparison operators
let IsGreater(x: Number, y: Number): Number = (x, y) -> Std.GreaterThan;

// Empty tuple support
let GetArguments(): Any = () -> Std.GetArgs;

// Test execution
(5) -> Add2;
(3, 4) -> MultiplyNumbers;
(10, 5) -> IsGreater;
(7, 2) -> AddThenMultiply;
() -> GetArguments;

