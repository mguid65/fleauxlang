// Tuple builtins (nested namespace API)
let Std.Tuple.Append<T>(t: Tuple(T...), item: T) : Tuple(T...) :: __builtin__;
let Std.Tuple.Prepend<T>(t: Tuple(T...), item: T) : Tuple(T...) :: __builtin__;
