let Std.Tuple.Min(t: Tuple(Any...)) : Any :: __builtin__;
let Std.Tuple.Max(t: Tuple(Any...)) : Any :: __builtin__;
let Std.Tuple.Reduce(t: Tuple(Any...), initial: Any, func: Any) : Any :: __builtin__;
let Std.Tuple.FindIndex(t: Tuple(Any...), pred: Any) : Number :: __builtin__;
let Std.Tuple.Any(t: Tuple(Any...), pred: Any) : Bool :: __builtin__;
let Std.Tuple.All(t: Tuple(Any...), pred: Any) : Bool :: __builtin__;
let Std.Tuple.Range(stop: Number) : Tuple(Any...) :: __builtin__;
// @brief Take the first `count` items from `tuple` and return them as a new Tuple
// ((1, 2, 3, 4), 2) -> Std.Take;
// Result: (1, 2)
let Std.Take(tuple: Tuple(Any...), count: Number) : Tuple(Any...) :: __builtin__;
// @brief Drop the first `count` items from `tuple` and return the remaining elements as a new Tuple
// ((1, 2, 3, 4), 2) -> Std.Drop;
// Result: (3, 4)
let Std.Drop(tuple: Tuple(Any...), count: Number) : Tuple(Any...) :: __builtin__;
// @brief Get the element at position `count` in `tuple`
// ((1, 2, 3, 4), 2) -> Std.ElementAt;
// Result: 3
let Std.ElementAt(tuple: Tuple(Any...), count: Number) : Any :: __builtin__;
// @brief Return the number of elements in `tuple`
// ((1, 2, 3),) -> Std.Length;
// Result: 3
let Std.Length(tuple: Tuple(Any...)) : Number :: __builtin__;
// @brief Slice a tuple. Accepts (tuple, stop), (tuple, start, stop), or (tuple, start, stop, step)
// ((1, 2, 3, 4), 1, 3) -> Std.Slice;
// Result: (2, 3)
let Std.Slice(tuple: Tuple(Any...), stop: Number) : Tuple(Any...) :: __builtin__;
// @brief Parse a string to a number
// ("42") -> Std.ToNum;
// Result: 42
let Std.ToNum(val: String) : Number :: __builtin__;
// @brief Return command-line arguments as a tuple of strings
// () -> Std.GetArgs;
let Std.GetArgs() : Tuple(Any...) :: __builtin__;

// ── Streaming file handle builtins ────────────────────────────────────────────
// @brief Open a file and return an opaque handle token.
// ("path/to/file", "r") -> Std.File.Open;
let Std.File.Open(path: String, mode: String) : Any :: __builtin__;

// @brief Read the next line from an open handle.
// Returns (handle, line, eof) — eof is True when no more lines remain.
// (handle) -> Std.File.ReadLine;
let Std.File.ReadLine(handle: Any) : Tuple(Any, String, Bool) :: __builtin__;

// @brief Read up to nbytes bytes from an open handle.
// Returns (handle, chunk, eof).
// (handle, 4096) -> Std.File.ReadChunk;
let Std.File.ReadChunk(handle: Any, nbytes: Number) : Tuple(Any, String, Bool) :: __builtin__;

// @brief Write a string chunk to an open handle. Returns the handle.
// (handle, "data") -> Std.File.WriteChunk;
let Std.File.WriteChunk(handle: Any, data: String) : Any :: __builtin__;

// @brief Flush an open handle. Returns the handle.
// (handle) -> Std.File.Flush;
let Std.File.Flush(handle: Any) : Any :: __builtin__;

// @brief Close an open handle. Returns True if was open, False if already closed.
// (handle) -> Std.File.Close;
let Std.File.Close(handle: Any) : Bool :: __builtin__;

// @brief Open a file, call func(handle), then always close. Returns func's result.
// ("path", "r", MyReader) -> Std.File.WithOpen;
let Std.File.WithOpen(path: String, mode: String, func: Any) : Any :: __builtin__;
// @brief Lift a single value into a 1-tuple
// (42) -> Std.Wrap;
// Result: (42,)
let Std.Wrap(val: Any) : Tuple(Any) :: __builtin__;
// @brief Extract the single value from a 1-tuple
// ((42,)) -> Std.Unwrap;
// Result: 42
let Std.Unwrap(tuple: Tuple(Any)) : Any :: __builtin__;

// ── Dictionary builtins (C++ backend) ─────────────────────────────────────────
// @brief Create an empty dictionary, or clone from an existing dictionary.
// () -> Std.Dict.Create;
// (dict) -> Std.Dict.Create;
let Std.Dict.Create() : Any :: __builtin__;
// @brief Return a new dictionary with key set to value.
// (dict, key, value) -> Std.Dict.Set;
let Std.Dict.Set(dict: Any, key: Any, value: Any) : Any :: __builtin__;
// @brief Get a value by key. Raises if key is missing.
// (dict, key) -> Std.Dict.Get;
let Std.Dict.Get(dict: Any, key: Any) : Any :: __builtin__;
// @brief Get a value by key, returning default when key is missing.
// (dict, key, default) -> Std.Dict.GetDefault;
let Std.Dict.GetDefault(dict: Any, key: Any, default: Any) : Any :: __builtin__;
// @brief Check if key exists.
// (dict, key) -> Std.Dict.Contains;
let Std.Dict.Contains(dict: Any, key: Any) : Bool :: __builtin__;
// @brief Return a new dictionary without the given key.
// (dict, key) -> Std.Dict.Delete;
let Std.Dict.Delete(dict: Any, key: Any) : Any :: __builtin__;
// @brief Return keys as tuple sorted by key string.
// (dict) -> Std.Dict.Keys;
let Std.Dict.Keys(dict: Any) : Tuple(Any...) :: __builtin__;
// @brief Return values as tuple sorted by key string.
// (dict) -> Std.Dict.Values;
let Std.Dict.Values(dict: Any) : Tuple(Any...) :: __builtin__;
// @brief Return (key, value) entries sorted by key string.
// (dict) -> Std.Dict.Entries;
let Std.Dict.Entries(dict: Any) : Tuple(Any...) :: __builtin__;
// @brief Return a new empty dictionary.
// (dict) -> Std.Dict.Clear;
let Std.Dict.Clear(dict: Any) : Any :: __builtin__;
// @brief Number of entries in dictionary.
// (dict) -> Std.Dict.Length;
let Std.Dict.Length(dict: Any) : Number :: __builtin__;

