let Std.Tuple.Prepend(t: Tuple(Any...), item: Any) : Tuple(Any...) :: __builtin__;
let Std.Tuple.Reverse(t: Tuple(Any...)) : Tuple(Any...) :: __builtin__;
let Std.Tuple.Contains(t: Tuple(Any...), item: Any) : Bool :: __builtin__;
let Std.Tuple.Zip(a: Tuple(Any...), b: Tuple(Any...)) : Tuple(Any...) :: __builtin__;
let Std.Tuple.Map(t: Tuple(Any...), func: Any) : Tuple(Any...) :: __builtin__;
let Std.Tuple.Filter(t: Tuple(Any...), pred: Any) : Tuple(Any...) :: __builtin__;
let Std.Tuple.Sort(t: Tuple(Any...)) : Tuple(Any...) :: __builtin__;
