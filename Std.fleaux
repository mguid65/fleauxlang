let Std.Println(args: Any...) : Tuple(Any...) :: __builtin__;
let Std.Printf(fmt_str: String, args: Any...) : Tuple(String, Any...) :: __builtin__;
let Std.Input() : String :: __builtin__;
let Std.Exit(code: Number) : Any :: __builtin__;
let Std.Add(lhs: Number, rhs: Number) : Number :: __builtin__;
let Std.Subtract(lhs: Number, rhs: Number) : Number :: __builtin__;
let Std.Multiply(lhs: Number, rhs: Number) : Number :: __builtin__;
let Std.Divide(lhs: Number, rhs: Number) : Number :: __builtin__;
let Std.Mod(lhs: Number, rhs: Number) : Number :: __builtin__;
let Std.Pow(lhs: Number, rhs: Number) : Number :: __builtin__;
let Std.Sqrt(val: Number) : Number :: __builtin__;
let Std.Tan(val: Number) : Number :: __builtin__;
let Std.Sin(val: Number) : Number :: __builtin__;
let Std.Cos(val: Number) : Number :: __builtin__;
let Std.GreaterThan(lhs: Any, rhs: Any) : Bool :: __builtin__;
let Std.LessThan(lhs: Any, rhs: Any) : Bool :: __builtin__;
let Std.GreaterOrEqual(lhs: Any, rhs: Any) : Bool :: __builtin__;
let Std.LessOrEqual(lhs: Any, rhs: Any) : Bool :: __builtin__;
let Std.Equal(lhs: Any, rhs: Any) : Bool :: __builtin__;
let Std.NotEqual(lhs: Any, rhs: Any) : Bool :: __builtin__;
let Std.Not(val: Any) : Any :: __builtin__;
let Std.And(lhs: Any, rhs: Any) : Bool :: __builtin__;
let Std.Or(lhs: Any, rhs: Any) : Bool :: __builtin__;
// @brief Return true_val if condition is truthy, false_val otherwise.
// ((x, 0) -> Std.GreaterOrEqual, x, (0, x) -> Std.Subtract) -> Std.Select;
// Note: both branches are always evaluated before Select is called.
let Std.Select(condition: Bool, true_val: Any, false_val: Any) : Any :: __builtin__;
// @brief Match value against ordered case tuples: (value, (pattern, handler), ...).
// Pattern '_' is a wildcard default and should be placed last.
// Pattern can also be a predicate callable '(x: Any): Bool = ...'.
// The first matching handler is invoked and receives the input value.
let Std.Match(value: Any, cases: Any...) : Any :: __builtin__;
// @brief Result helpers use tagged tuples: (Std.Ok, payload) or (Std.Err, payload).
// Std.Ok and Std.Err are language constants that desugar to true and false respectively.
let Std.Result.Ok(value: Any) : Tuple(Bool, Any) :: __builtin__;
let Std.Result.Err(error: Any) : Tuple(Bool, Any) :: __builtin__;
let Std.Result.Tag(result: Tuple(Bool, Any)) : Bool :: __builtin__;
let Std.Result.Payload(result: Tuple(Bool, Any)) : Any :: __builtin__;
let Std.Result.IsOk(result: Tuple(Bool, Any)) : Bool :: __builtin__;
let Std.Result.IsErr(result: Tuple(Bool, Any)) : Bool :: __builtin__;
let Std.Result.Unwrap(result: Tuple(Bool, Any)) : Any :: __builtin__;
let Std.Result.UnwrapErr(result: Tuple(Bool, Any)) : Any :: __builtin__;
// @brief Invoke a callable with a value and capture runtime exceptions as Result.Err(message).
// (value, func) -> Std.Try;
let Std.Try(value: Any, func: Any) : Tuple(Bool, Any) :: __builtin__;
// @brief Experimental parallel map over tuple items.
// (items, func) -> Std.Exp.Parallel;
// Returns Std.Result.Ok(tuple_of_results) or Std.Result.Err((index, message)).
let Std.Exp.Parallel(items: Tuple(Any...), func: Any) : Tuple(Bool, Any) :: __builtin__;
// @brief Apply a function reference to a value.
// (5, Double) -> Std.Apply;  is equivalent to  (5) -> Double
let Std.Apply(value: Any, func: Any) : Any :: __builtin__;
// @brief Conditionally apply one of two function references to a value.
// Only the chosen function executes - the other branch is never called.
// ((x, 0) -> Std.GreaterThan, x, Double, Negate) -> Std.Branch;
let Std.Branch(condition: Bool, value: Any, true_func: Any, false_func: Any) : Any :: __builtin__;
// @brief Iterate state while continue_func(state) is truthy.
// Returns final state when condition becomes false.
// ((n, acc), Continue, Step) -> Std.Loop;
let Std.Loop(state: Any, continue_func: Any, step_func: Any) : Any :: __builtin__;
// @brief Iterate with a hard iteration cap; raises if cap is exceeded.
// ((n, acc), Continue, Step, 1000) -> Std.LoopN;
let Std.LoopN(state: Any, continue_func: Any, step_func: Any, max_iters: Number) : Any :: __builtin__;
let Std.UnaryPlus(val: Any) : Any :: __builtin__;
let Std.UnaryMinus(val: Any) : Any :: __builtin__;
let Std.ToString(val: Any) : String :: __builtin__;
