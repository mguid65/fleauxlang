let Std.Tuple.FindIndex<T>(t: Tuple(T...), pred: (T) => Bool) : Int64 :: __builtin__;
let Std.Tuple.Any<T>(t: Tuple(T...), pred: (T) => Bool) : Bool :: __builtin__;
let Std.Tuple.All<T>(t: Tuple(T...), pred: (T) => Bool) : Bool :: __builtin__;
let Std.Tuple.Range(stop: Int64) : Tuple(Int64...) :: __builtin__;
// @brief Take the first `count` items from `tuple` and return them as a new Tuple
// ((1, 2, 3, 4), 2) -> Std.Take;
// Result: (1, 2)
let Std.Take<T>(tuple: Tuple(T...), count: Int64) : Tuple(T...) :: __builtin__;
// @brief Drop the first `count` items from `tuple` and return the remaining elements as a new Tuple
// ((1, 2, 3, 4), 2) -> Std.Drop;
// Result: (3, 4)
let Std.Drop<T>(tuple: Tuple(T...), count: Int64) : Tuple(T...) :: __builtin__;
// @brief Get the element at position `count` in `tuple`
// ((1, 2, 3, 4), 2) -> Std.ElementAt;
// Result: 3
let Std.ElementAt<T>(tuple: Tuple(T...), count: Int64) : T :: __builtin__;
// @brief Return the number of elements in `tuple`
// ((1, 2, 3),) -> Std.Length;
// Result: 3
let Std.Length<T>(tuple: Tuple(T...)) : Int64 :: __builtin__;
// @brief Slice a tuple. Accepts (tuple, stop), (tuple, start, stop), or (tuple, start, stop, step)
// ((1, 2, 3, 4), 1, 3) -> Std.Slice;
// Result: (2, 3)
let Std.Slice<T>(tuple: Tuple(T...), stop: Int64) : Tuple(T...) :: __builtin__;
// @brief Parse a string to a number
// ("42") -> Std.ToNum;
// Result: 42
let Std.ToNum(val: String) : Float64 :: __builtin__;
// @brief Return command-line arguments as a tuple of strings
// () -> Std.GetArgs;
let Std.GetArgs() : Tuple(String...) :: __builtin__;

// Streaming file handle builtins
// @brief Open a file and return an opaque handle token.
// ("path/to/file", "r") -> Std.File.Open;
let Std.File.Open(path: String, mode: String) : FileHandle :: __builtin__;

// @brief Read the next line from an open handle.
// Returns (handle, line, eof) — eof is True when no more lines remain.
// (handle) -> Std.File.ReadLine;
let Std.File.ReadLine(handle: FileHandle) : Tuple(FileHandle, String, Bool) :: __builtin__;

// @brief Read up to nbytes bytes from an open handle.
// Returns (handle, chunk, eof).
// (handle, 4096) -> Std.File.ReadChunk;
let Std.File.ReadChunk(handle: FileHandle, nbytes: Int64) : Tuple(FileHandle, String, Bool) :: __builtin__;

// @brief Write a string chunk to an open handle. Returns the handle.
// (handle, "data") -> Std.File.WriteChunk;
let Std.File.WriteChunk(handle: FileHandle, data: String) : FileHandle :: __builtin__;

// @brief Flush an open handle. Returns the handle.
// (handle) -> Std.File.Flush;
let Std.File.Flush(handle: FileHandle) : FileHandle :: __builtin__;

// @brief Close an open handle. Returns True if was open, False if already closed.
// (handle) -> Std.File.Close;
let Std.File.Close(handle: FileHandle) : Bool :: __builtin__;

// @brief Open a file, call func(handle), then always close. Returns func's result.
// ("path", "r", MyReader) -> Std.File.WithOpen;
let Std.File.WithOpen<R>(path: String, mode: String, func: (FileHandle) => R) : R :: __builtin__;
// @brief Lift a single value into a 1-tuple
// (42) -> Std.Wrap;
// Result: (42,)
let Std.Wrap<T>(val: T) : Tuple(T) :: __builtin__;
// @brief Extract the single value from a 1-tuple
// ((42,)) -> Std.Unwrap;
// Result: 42
let Std.Unwrap<T>(tuple: Tuple(T)) : T :: __builtin__;

// Dictionary builtins
// @brief Create an empty dictionary.
// The nullary overload keeps the current empty-dictionary seed policy.
// () -> Std.Dict.Create;
let Std.Dict.Create() : Dict(Any, Any) :: __builtin__;
// @brief Clone an existing dictionary while preserving its key and value channels.
// (dict) -> Std.Dict.Create;
let Std.Dict.Create<K, V>(dict: Dict(K, V)) : Dict(K, V) :: __builtin__;
// @brief Return a new dictionary with key set to value.
// (dict, key, value) -> Std.Dict.Set;
let Std.Dict.Set<K, V>(dict: Dict(K, V), key: K, value: V) : Dict(K, V) :: __builtin__;
// @brief Get a value by key. Raises if key is missing.
// (dict, key) -> Std.Dict.Get;
let Std.Dict.Get<K, V>(dict: Dict(K, V), key: K) : V :: __builtin__;
// @brief Get a value by key, returning default when key is missing.
// (dict, key, default) -> Std.Dict.GetDefault;
let Std.Dict.GetDefault<K, V>(dict: Dict(K, V), key: K, default: V) : V :: __builtin__;
// @brief Check if key exists.
// (dict, key) -> Std.Dict.Contains;
let Std.Dict.Contains<K, V>(dict: Dict(K, V), key: K) : Bool :: __builtin__;
// @brief Return a new dictionary without the given key.
// (dict, key) -> Std.Dict.Delete;
let Std.Dict.Delete<K, V>(dict: Dict(K, V), key: K) : Dict(K, V) :: __builtin__;
// @brief Return keys as tuple sorted by key string.
// (dict) -> Std.Dict.Keys;
let Std.Dict.Keys<K, V>(dict: Dict(K, V)) : Tuple(K...) :: __builtin__;
// @brief Return values as tuple sorted by key string.
// (dict) -> Std.Dict.Values;
let Std.Dict.Values<K, V>(dict: Dict(K, V)) : Tuple(V...) :: __builtin__;
// @brief Return (key, value) entries sorted by key string.
// (dict) -> Std.Dict.Entries;
let Std.Dict.Entries<K, V>(dict: Dict(K, V)) : Tuple(Tuple(K, V)...) :: __builtin__;
// @brief Return a new empty dictionary.
// (dict) -> Std.Dict.Clear;
let Std.Dict.Clear<K, V>(dict: Dict(K, V)) : Dict(K, V) :: __builtin__;
// @brief Float64 of entries in dictionary.
// (dict) -> Std.Dict.Length;
let Std.Dict.Length<K, V>(dict: Dict(K, V)) : Int64 :: __builtin__;

// Array support builtins
// @brief Get element at index from a 1-D array.
// (array, index) -> Std.Array.GetAt;
let Std.Array.GetAt<T>(array: Tuple(T...), index: Int64) : T :: __builtin__;
// @brief Return a new array with one element replaced.
// (array, index, value) -> Std.Array.SetAt;
let Std.Array.SetAt<T>(array: Tuple(T...), index: Int64, value: T) : Tuple(T...) :: __builtin__;
// @brief Insert an element at index and return a new array.
// (array, index, value) -> Std.Array.InsertAt;
let Std.Array.InsertAt<T>(array: Tuple(T...), index: Int64, value: T) : Tuple(T...) :: __builtin__;
// @brief Remove an element at index and return a new array.
// (array, index) -> Std.Array.RemoveAt;
let Std.Array.RemoveAt<T>(array: Tuple(T...), index: Int64) : Tuple(T...) :: __builtin__;
// @brief Slice a 1-D array using [start, stop).
// (array, start, stop) -> Std.Array.Slice;
let Std.Array.Slice<T>(array: Tuple(T...), start: Int64, stop: Int64) : Tuple(T...) :: __builtin__;
// @brief Concatenate two 1-D arrays.
// (lhs, rhs) -> Std.Array.Concat;
let Std.Array.Concat<T>(lhs: Tuple(T...), rhs: Tuple(T...)) : Tuple(T...) :: __builtin__;
// @brief Set element at (row, col) in a 2D array (tuple of tuples).
// (grid, row, col, value) -> Std.Array.SetAt2D;
// Returns a new grid with the element replaced.
let Std.Array.SetAt2D<T>(grid: Tuple(Tuple(T...)...), row: Int64, col: Int64, value: T) : Tuple(Tuple(T...)...) :: __builtin__;
// @brief Fill a contiguous region in a tuple with a value.
// (tuple, start_index, length, value) -> Std.Array.Fill;
// Returns a new tuple with elements [start_index, start_index+length) set to value.
let Std.Array.Fill<T>(tuple: Tuple(T...), start_index: Int64, length: Int64, value: T) : Tuple(T...) :: __builtin__;
// @brief Transpose a 2D array (swap rows and columns).
// (grid) -> Std.Array.Transpose2D;
// Returns a new grid where rows become columns.
let Std.Array.Transpose2D<T>(grid: Tuple(Tuple(T...)...)) : Tuple(Tuple(T...)...) :: __builtin__;
// @brief Extract a rectangular slice from a 2D array.
// (grid, row_start, row_end, col_start, col_end) -> Std.Array.Slice2D;
// Returns a new grid containing elements in [row_start, row_end) x [col_start, col_end).
let Std.Array.Slice2D<T>(grid: Tuple(Tuple(T...)...), row_start: Int64, row_end: Int64, col_start: Int64, col_end: Int64) : Tuple(Tuple(T...)...) :: __builtin__;
// @brief Reshape a flattened array into a 2D grid.
// (flat_array, rows: Float64, cols: Float64) -> Std.Array.Reshape;
// Returns a grid of rows x cols, interpreting flat_array in row-major order.
let Std.Array.Reshape<T>(flat_array: Tuple(T...), rows: Int64, cols: Int64) : Tuple(Tuple(T...)...) :: __builtin__;
// @brief Return the rank (number of dimensions) of a rectangular array value.
// (value) -> Std.Array.Rank;
let Std.Array.Rank(value: Any) : Int64 :: __builtin__;
// @brief Return the shape tuple for a rectangular array value.
// Shape is represented structurally as Tuple(Int64...), not as a dedicated surface type.
// (value) -> Std.Array.Shape;
let Std.Array.Shape(value: Any) : Tuple(Int64...) :: __builtin__;
// @brief Flatten an n-D array value in row-major order.
// (value) -> Std.Array.Flatten;
let Std.Array.Flatten(value: Any) : Tuple(Any...) :: __builtin__;
// @brief Get element using n-D indices tuple.
// Indices are represented structurally as Tuple(Int64...), not as a dedicated surface type.
// (value, indices) -> Std.Array.GetAtND;
let Std.Array.GetAtND(value: Any, indices: Tuple(Int64...)) : Any :: __builtin__;
// @brief Return a new n-D array with one element replaced at indices.
// (value, indices, replacement) -> Std.Array.SetAtND;
let Std.Array.SetAtND(value: Any, indices: Tuple(Int64...), replacement: Any) : Any :: __builtin__;
// @brief Reshape a flat array into an n-D rectangular array using shape tuple.
// (flat_array, shape) -> Std.Array.ReshapeND;
let Std.Array.ReshapeND(flat_array: Tuple(Any...), shape: Tuple(Int64...)) : Any :: __builtin__;
