let Std.String.Slice(s: String, start: Int64, stop: Int64) : String :: __builtin__;
let Std.String.Find(s: String, sub: String, start: Int64) : Int64 :: __builtin__;
let Std.String.Format(fmt_str: String, args: Any...) : String :: __builtin__;
let Std.String.Regex.IsMatch(s: String, pattern: String) : Bool :: __builtin__;
let Std.String.Regex.Find(s: String, pattern: String) : Int64 :: __builtin__;
let Std.String.Regex.Replace(s: String, pattern: String, repl: String) : String :: __builtin__;
let Std.String.Regex.Split(s: String, pattern: String) : Tuple(String...) :: __builtin__;
// Path/filesystem builtins (nested namespace API)
let Std.OS.Cwd() : String :: __builtin__;
let Std.OS.Home() : String :: __builtin__;
let Std.OS.TempDir() : String :: __builtin__;
// On web/WASM targets, OS/path/file operations run inside an in-memory virtual filesystem.
// The default layout is rooted at /workspace, with /home/web_user and /tmp also available.
// @brief Execute a shell command and return (exit_code, combined_output).
// ("echo hi") -> Std.OS.Exec;
// On web/WASM targets this returns (-1, message) because browsers do not expose shell execution.
let Std.OS.Exec(command: String) : Tuple(Int64, String) :: __builtin__;
let Std.OS.MakeTempFile() : String :: __builtin__;
let Std.OS.MakeTempDir() : String :: __builtin__;
// On web/WASM targets, Std.OS.Env / HasEnv / SetEnv / UnsetEnv operate on a small virtual environment.
// Builtin values include PWD, HOME, USERPROFILE, TMPDIR, TMP, and TEMP.
let Std.OS.Env(name: String) : String | Null :: __builtin__;
let Std.OS.HasEnv(name: String) : Bool :: __builtin__;
let Std.OS.SetEnv(name: String, value: String) : String :: __builtin__;
let Std.OS.UnsetEnv(name: String) : Bool :: __builtin__;
let Std.OS.IsWindows() : Bool :: __builtin__;
let Std.OS.IsLinux() : Bool :: __builtin__;
let Std.OS.IsMacOS() : Bool :: __builtin__;
let Std.Path.Join(lhs: String, rhs: String) : String :: __builtin__;
let Std.Path.Normalize(path: String) : String :: __builtin__;
let Std.Path.Basename(path: String) : String :: __builtin__;
let Std.Path.Dirname(path: String) : String :: __builtin__;
let Std.Path.Exists(path: String) : Bool :: __builtin__;
let Std.Path.IsFile(path: String) : Bool :: __builtin__;
let Std.Path.IsDir(path: String) : Bool :: __builtin__;
let Std.Path.Absolute(path: String) : String :: __builtin__;
let Std.Path.Extension(path: String) : String :: __builtin__;
let Std.Path.Stem(path: String) : String :: __builtin__;
let Std.Path.WithExtension(path: String, ext: String) : String :: __builtin__;
let Std.Path.WithBasename(path: String, name: String) : String :: __builtin__;
let Std.File.ReadText(path: String) : String :: __builtin__;
let Std.File.WriteText(path: String, text: String) : String :: __builtin__;
let Std.File.AppendText(path: String, text: String) : String :: __builtin__;
