// @brief Extract the value from a one-element tuple.
// @param T Generic value type.
// @param tuple Input tuple value. Type: Tuple(T).
// @return A value of type T.
let Std.Unwrap<T>(tuple: Tuple(T)) : T :: __builtin__;


// Dictionary builtins
// @brief Create or clone a dictionary value.
// @return A value of type Dict(Any, Any).
let Std.Dict.Create() : Dict(Any, Any) :: __builtin__;

// @brief Create or clone a dictionary value.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @return A value of type Dict(K, V).
let Std.Dict.Create<K, V>(dict: Dict(K, V)) : Dict(K, V) :: __builtin__;

// @brief Return a dictionary with key set to value.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @param key Dictionary key. Type: K.
// @param value Input value. Type: V.
// @return A value of type Dict(K, V).
let Std.Dict.Set<K, V>(dict: Dict(K, V), key: K, value: V) : Dict(K, V) :: __builtin__;

// @brief Return the value stored at key.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @param key Dictionary key. Type: K.
// @return A value of type V.
let Std.Dict.Get<K, V>(dict: Dict(K, V), key: K) : V :: __builtin__;

// @brief Return the value stored at key or a default when key is missing.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @param key Dictionary key. Type: K.
// @param default Fallback value used when a lookup misses. Type: V.
// @return A value of type V.
let Std.Dict.GetDefault<K, V>(dict: Dict(K, V), key: K, default: V) : V :: __builtin__;

// @brief Return whether a dictionary contains key.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @param key Dictionary key. Type: K.
// @return A value of type Bool.
let Std.Dict.Contains<K, V>(dict: Dict(K, V), key: K) : Bool :: __builtin__;

// @brief Return a dictionary without key.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @param key Dictionary key. Type: K.
// @return A value of type Dict(K, V).
let Std.Dict.Delete<K, V>(dict: Dict(K, V), key: K) : Dict(K, V) :: __builtin__;

// @brief Return a dictionary with overlay entries applied over the base dictionary.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict_base Base dictionary value. Type: Dict(K, V).
// @param dict_overlay Overlay dictionary whose entries take precedence. Type: Dict(K, V).
// @return A value of type Dict(K, V).
let Std.Dict.Merge<K, V>(dict_base: Dict(K, V), dict_overlay: Dict(K, V)) : Dict(K, V) :: __builtin__;

// @brief Return dictionary keys in sorted key order.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @return A value of type Tuple(K...).
let Std.Dict.Keys<K, V>(dict: Dict(K, V)) : Tuple(K...) :: __builtin__;

// @brief Return dictionary values in sorted key order.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @return A value of type Tuple(V...).
let Std.Dict.Values<K, V>(dict: Dict(K, V)) : Tuple(V...) :: __builtin__;

// @brief Return dictionary entries in sorted key order.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @return A value of type Tuple(Tuple(K, V)...).
let Std.Dict.Entries<K, V>(dict: Dict(K, V)) : Tuple(Tuple(K, V)...) :: __builtin__;

// @brief Return an empty dictionary with the same channels.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @return A value of type Dict(K, V).
let Std.Dict.Clear<K, V>(dict: Dict(K, V)) : Dict(K, V) :: __builtin__;

// @brief Return the number of entries in a dictionary.
// @param K Generic dictionary key type.
// @param V Generic dictionary value type.
// @param dict Input dictionary value. Type: Dict(K, V).
// @return A value of type Int64.
let Std.Dict.Length<K, V>(dict: Dict(K, V)) : Int64 :: __builtin__;


// Array builtins
// @brief Return the array element at index.
// @param T Generic value type.
// @param array Input array value. Type: Tuple(T...).
// @param index Zero-based index. Type: Int64.
// @return A value of type T.
let Std.Array.GetAt<T>(array: Tuple(T...), index: Int64) : T :: __builtin__;

// @brief Return an array with one element replaced at index.
// @param T Generic value type.
// @param array Input array value. Type: Tuple(T...).
// @param index Zero-based index. Type: Int64.
// @param value Input value. Type: T.
// @return A value of type Tuple(T...).
let Std.Array.SetAt<T>(array: Tuple(T...), index: Int64, value: T) : Tuple(T...) :: __builtin__;

// @brief Return an array with value inserted at index.
// @param T Generic value type.
// @param array Input array value. Type: Tuple(T...).
// @param index Zero-based index. Type: Int64.
// @param value Input value. Type: T.
// @return A value of type Tuple(T...).
let Std.Array.InsertAt<T>(array: Tuple(T...), index: Int64, value: T) : Tuple(T...) :: __builtin__;

// @brief Return an array with the element at index removed.
// @param T Generic value type.
// @param array Input array value. Type: Tuple(T...).
// @param index Zero-based index. Type: Int64.
// @return A value of type Tuple(T...).
let Std.Array.RemoveAt<T>(array: Tuple(T...), index: Int64) : Tuple(T...) :: __builtin__;

// @brief Return a one-dimensional array slice.
// @param T Generic value type.
// @param array Input array value. Type: Tuple(T...).
// @param start Starting index. Type: Int64.
// @param stop Exclusive ending index. Type: Int64.
// @return A value of type Tuple(T...).
let Std.Array.Slice<T>(array: Tuple(T...), start: Int64, stop: Int64) : Tuple(T...) :: __builtin__;

// @brief Concatenate two one-dimensional arrays.
// @param T Generic value type.
// @param lhs Left-hand operand value. Type: Tuple(T...).
// @param rhs Right-hand operand value. Type: Tuple(T...).
// @return A value of type Tuple(T...).
let Std.Array.Concat<T>(lhs: Tuple(T...), rhs: Tuple(T...)) : Tuple(T...) :: __builtin__;

// @brief Return a two-dimensional array with one element replaced at row and col.
// @param T Generic value type.
// @param grid Two-dimensional array value. Type: Tuple(Tuple(T...)...).
// @param row Row index. Type: Int64.
// @param col Column index. Type: Int64.
// @param value Input value. Type: T.
// @return A value of type Tuple(Tuple(T...)...).
let Std.Array.SetAt2D<T>(grid: Tuple(Tuple(T...)...), row: Int64, col: Int64, value: T) : Tuple(Tuple(T...)...) :: __builtin__;

// @brief Return a tuple with a contiguous region filled with value.
// @param T Generic value type.
// @param tuple Input tuple value. Type: Tuple(T...).
// @param start_index Starting index. Type: Int64.
// @param length Number of elements to include. Type: Int64.
// @param value Input value. Type: T.
// @return A value of type Tuple(T...).
let Std.Array.Fill<T>(tuple: Tuple(T...), start_index: Int64, length: Int64, value: T) : Tuple(T...) :: __builtin__;

// @brief Transpose a two-dimensional array.
// @param T Generic value type.
// @param grid Two-dimensional array value. Type: Tuple(Tuple(T...)...).
// @return A value of type Tuple(Tuple(T...)...).
let Std.Array.Transpose2D<T>(grid: Tuple(Tuple(T...)...)) : Tuple(Tuple(T...)...) :: __builtin__;

// @brief Return a rectangular slice from a two-dimensional array.
// @param T Generic value type.
// @param grid Two-dimensional array value. Type: Tuple(Tuple(T...)...).
// @param row_start Starting row index. Type: Int64.
// @param row_end Exclusive ending row index. Type: Int64.
// @param col_start Starting column index. Type: Int64.
// @param col_end Exclusive ending column index. Type: Int64.
// @return A value of type Tuple(Tuple(T...)...).
let Std.Array.Slice2D<T>(grid: Tuple(Tuple(T...)...), row_start: Int64, row_end: Int64, col_start: Int64, col_end: Int64) : Tuple(Tuple(T...)...) :: __builtin__;

// @brief Reshape a flat array into a two-dimensional grid.
// @param T Generic value type.
// @param flat_array Flattened array value. Type: Tuple(T...).
// @param rows Number of rows. Type: Int64.
// @param cols Value for parameter cols. Type: Int64.
// @return A value of type Tuple(Tuple(T...)...).
let Std.Array.Reshape<T>(flat_array: Tuple(T...), rows: Int64, cols: Int64) : Tuple(Tuple(T...)...) :: __builtin__;

// @brief Return the rank of a rectangular array value.
// @param value Input value. Type: Any.
// @return A value of type Int64.
let Std.Array.Rank(value: Any) : Int64 :: __builtin__;

// @brief Return the shape tuple for a rectangular array value.
// @param value Input value. Type: Any.
// @return A value of type Tuple(Int64...).
let Std.Array.Shape(value: Any) : Tuple(Int64...) :: __builtin__;

// @brief Flatten a rectangular array value in row-major order.
// @param value Input value. Type: Any.
// @return A value of type Tuple(Any...).
let Std.Array.Flatten(value: Any) : Tuple(Any...) :: __builtin__;

// @brief Return the array element at the requested index tuple.
// @param value Input value. Type: Any.
// @param indices Tuple of zero-based indices. Type: Tuple(Int64...).
// @return A value of type Any.
let Std.Array.GetAtND(value: Any, indices: Tuple(Int64...)) : Any :: __builtin__;

// @brief Return an array with one element replaced at the requested index tuple.
// @param value Input value. Type: Any.
// @param indices Tuple of zero-based indices. Type: Tuple(Int64...).
// @param replacement Replacement value. Type: Any.
// @return A value of type Any.
let Std.Array.SetAtND(value: Any, indices: Tuple(Int64...), replacement: Any) : Any :: __builtin__;

// @brief Reshape a flat array into an n-dimensional rectangular array.
// @param flat_array Flattened array value. Type: Tuple(Any...).
// @param shape Tuple describing the target shape. Type: Tuple(Int64...).
// @return A value of type Any.
let Std.Array.ReshapeND(flat_array: Tuple(Any...), shape: Tuple(Int64...)) : Any :: __builtin__;
