// Opaque standard-library handle surface types
type TaskHandle = Any;
type FileHandle = Any;

// Core builtins
// @brief Print values to the active output stream.
// @param args Additional values. Type: Any....
// @return A tuple containing the printed values.
let Std.Println(args: Any...) : Tuple(Any...) :: __builtin__;

// @brief Format values and print the result to the active output stream.
// @param fmt_str Format string. Type: String.
// @param args Additional values. Type: Any....
// @return A tuple containing the formatted string followed by the input values.
let Std.Printf(fmt_str: String, args: Any...) : Tuple(String, Any...) :: __builtin__;

// @brief Read a line of input from the active input stream.
// @return The input line as a String.
let Std.Input() : String :: __builtin__;

// @brief Return help text for the named symbol.
// @param name Name string. Type: String.
// @return Help text for the requested symbol.
let Std.Help(name: String) : String :: __builtin__;

// @brief Return the runtime type name of a value.
// @param value Input value. Type: Any.
// @return The runtime type name as a String.
let Std.Type(value: Any) : String :: __builtin__;

// @brief Reinterpret a value as an explicitly requested type.
// @param value Input value. Type: Any.
// @return The same runtime value, checked against the requested type parameter.
let Std.Cast<T>(value: Any) : T :: __builtin__;

// @brief Convert a value to Int64 explicitly.
// @param value Input value. Type: Any.
// @return A value of type Int64.
let Std.ToInt64(value: Any) : Int64 :: __builtin__;

// @brief Convert a value to UInt64 explicitly.
// @param value Input value. Type: Any.
// @return A value of type UInt64.
let Std.ToUInt64(value: Any) : UInt64 :: __builtin__;

// @brief Convert a value to Float64 explicitly.
// @param value Input value. Type: Any.
// @return A value of type Float64.
let Std.ToFloat64(value: Any) : Float64 :: __builtin__;

// @brief Terminate the current process.
// @return This builtin never returns.
let Std.Exit() : Never :: __builtin__;

// @brief Terminate the current process.
// @param code Value for parameter code. Type: Int64.
// @return This builtin never returns.
let Std.Exit(code: Int64) : Never :: __builtin__;

// @brief Add two numeric values of the same numeric kind.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Float64 | Int64 | UInt64.
let Std.Add(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Float64 | Int64 | UInt64 :: __builtin__;

// @brief Subtract rhs from lhs for matching numeric kinds.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Float64 | Int64 | UInt64.
let Std.Subtract(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Float64 | Int64 | UInt64 :: __builtin__;

// @brief Multiply two numeric values of the same numeric kind.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Float64 | Int64 | UInt64.
let Std.Multiply(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Float64 | Int64 | UInt64 :: __builtin__;

// @brief Divide lhs by rhs for matching numeric kinds.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Float64 | Int64 | UInt64.
let Std.Divide(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Float64 | Int64 | UInt64 :: __builtin__;

// @brief Compute the modulus or remainder for matching numeric kinds.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Float64 | Int64 | UInt64.
let Std.Mod(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Float64 | Int64 | UInt64 :: __builtin__;

// @brief Raise lhs to the power of rhs for matching numeric kinds.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Float64 | Int64 | UInt64.
let Std.Pow(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Float64 | Int64 | UInt64 :: __builtin__;

// @brief Compute the bitwise AND of two Int64 values.
// @param lhs Left-hand operand value. Type: Int64.
// @param rhs Right-hand operand value. Type: Int64.
// @return A value of type Int64.
let Std.Bit.And(lhs: Int64, rhs: Int64) : Int64 :: __builtin__;

// @brief Compute the bitwise OR of two Int64 values.
// @param lhs Left-hand operand value. Type: Int64.
// @param rhs Right-hand operand value. Type: Int64.
// @return A value of type Int64.
let Std.Bit.Or(lhs: Int64, rhs: Int64) : Int64 :: __builtin__;

// @brief Compute the bitwise XOR of two Int64 values.
// @param lhs Left-hand operand value. Type: Int64.
// @param rhs Right-hand operand value. Type: Int64.
// @return A value of type Int64.
let Std.Bit.Xor(lhs: Int64, rhs: Int64) : Int64 :: __builtin__;

// @brief Compute the bitwise NOT of an Int64 value.
// @param value Input value. Type: Int64.
// @return A value of type Int64.
let Std.Bit.Not(value: Int64) : Int64 :: __builtin__;

// @brief Shift an Int64 value left by the requested bit count.
// @param value Input value. Type: Int64.
// @param bits Bit count. Type: Int64.
// @return A value of type Int64.
let Std.Bit.ShiftLeft(value: Int64, bits: Int64) : Int64 :: __builtin__;

// @brief Shift an Int64 value right by the requested bit count.
// @param value Input value. Type: Int64.
// @param bits Bit count. Type: Int64.
// @return A value of type Int64.
let Std.Bit.ShiftRight(value: Int64, bits: Int64) : Int64 :: __builtin__;

// @brief Compare two numeric values and return whether lhs is greater than rhs.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Bool.
let Std.GreaterThan(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Bool :: __builtin__;

// @brief Compare two numeric values and return whether lhs is less than rhs.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Bool.
let Std.LessThan(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Bool :: __builtin__;

// @brief Compare two numeric values and return whether lhs is greater than or equal to rhs.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Bool.
let Std.GreaterOrEqual(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Bool :: __builtin__;

// @brief Compare two numeric values and return whether lhs is less than or equal to rhs.
// @param lhs Left-hand operand value. Type: Float64 | Int64 | UInt64.
// @param rhs Right-hand operand value. Type: Float64 | Int64 | UInt64.
// @return A value of type Bool.
let Std.LessOrEqual(lhs: Float64 | Int64 | UInt64, rhs: Float64 | Int64 | UInt64) : Bool :: __builtin__;

// @brief Return whether two values are equal.
// @param T Generic value type.
// @param lhs Left-hand operand value. Type: T.
// @param rhs Right-hand operand value. Type: T.
// @return A value of type Bool.
let Std.Equal<T>(lhs: T, rhs: T) : Bool :: __builtin__;

// @brief Return whether two values are not equal.
// @param T Generic value type.
// @param lhs Left-hand operand value. Type: T.
// @param rhs Right-hand operand value. Type: T.
// @return A value of type Bool.
let Std.NotEqual<T>(lhs: T, rhs: T) : Bool :: __builtin__;

// @brief Invert a Bool value.
// @param val Value for parameter val. Type: Bool.
// @return A value of type Bool.
let Std.Not(val: Bool) : Bool :: __builtin__;

// @brief Compute the logical AND of two Bool values.
// @param lhs Left-hand operand value. Type: Bool.
// @param rhs Right-hand operand value. Type: Bool.
// @return A value of type Bool.
let Std.And(lhs: Bool, rhs: Bool) : Bool :: __builtin__;

// @brief Compute the logical OR of two Bool values.
// @param lhs Left-hand operand value. Type: Bool.
// @param rhs Right-hand operand value. Type: Bool.
// @return A value of type Bool.
let Std.Or(lhs: Bool, rhs: Bool) : Bool :: __builtin__;

// @brief Return one of two values based on a Bool condition.
// @param T Generic value type.
// @param condition Boolean condition to evaluate. Type: Bool.
// @param true_val Value returned when condition is true. Type: T.
// @param false_val Value returned when condition is false. Type: T.
// @return A value of type T.
let Std.Select<T>(condition: Bool, true_val: T, false_val: T) : T :: __builtin__;

// @brief Match a value against ordered pattern and handler cases.
// @param value Input value. Type: Any.
// @param cases Value for parameter cases. Type: Any....
// @return A value of type Any.
let Std.Match(value: Any, cases: Any...) : Any :: __builtin__;

// @brief Construct a Result value tagged as Ok.
// @param T Generic value type.
// @param value Input value. Type: T.
// @return A value of type Result(T, Any).
let Std.Result.Ok<T>(value: T) : Result(T, Any) :: __builtin__;

// @brief Construct a Result value tagged as Err.
// @param E Generic error type.
// @param error Error payload value. Type: E.
// @return A value of type Result(Any, E).
let Std.Result.Err<E>(error: E) : Result(Any, E) :: __builtin__;

// @brief Return the Ok or Err tag for a Result value.
// @param T Generic value type.
// @param E Generic error type.
// @param result Result value. Type: Result(T, E).
// @return A value of type Bool.
let Std.Result.Tag<T, E>(result: Result(T, E)) : Bool :: __builtin__;

// @brief Return the payload stored in a Result value.
// @param T Generic value type.
// @param E Generic error type.
// @param result Result value. Type: Result(T, E).
// @return A value of type T | E.
let Std.Result.Payload<T, E>(result: Result(T, E)) : T | E :: __builtin__;

// @brief Return whether a Result value is tagged as Ok.
// @param T Generic value type.
// @param E Generic error type.
// @param result Result value. Type: Result(T, E).
// @return A value of type Bool.
let Std.Result.IsOk<T, E>(result: Result(T, E)) : Bool :: __builtin__;

// @brief Return whether a Result value is tagged as Err.
// @param T Generic value type.
// @param E Generic error type.
// @param result Result value. Type: Result(T, E).
// @return A value of type Bool.
let Std.Result.IsErr<T, E>(result: Result(T, E)) : Bool :: __builtin__;

// @brief Return the Ok payload from a Result value or raise on Err.
// @param T Generic value type.
// @param E Generic error type.
// @param result Result value. Type: Result(T, E).
// @return A value of type T.
let Std.Result.Unwrap<T, E>(result: Result(T, E)) : T :: __builtin__;

// @brief Return the Err payload from a Result value or raise on Ok.
// @param T Generic value type.
// @param E Generic error type.
// @param result Result value. Type: Result(T, E).
// @return A value of type E.
let Std.Result.UnwrapErr<T, E>(result: Result(T, E)) : E :: __builtin__;

// @brief Invoke a callable and capture runtime exceptions as Result.Err.
// @param T Generic value type.
// @param U Generic result type.
// @param value Input value. Type: T.
// @param func Callable to invoke. Type: (T) => U.
// @return A value of type Result(U, String).
let Std.Try<T, U>(value: T, func: (T) => U) : Result(U, String) :: __builtin__;

// @brief Apply a callable to each tuple item in parallel.
// @param T Generic value type.
// @param U Generic result type.
// @param items Tuple of input items. Type: Tuple(T...).
// @param func Callable to invoke. Type: (T) => U.
// @return A value of type Result(Tuple(U...), Tuple(Int64, String)).
let Std.Parallel.Map<T, U>(items: Tuple(T...), func: (T) => U) : Result(Tuple(U...), Tuple(Int64, String)) :: __builtin__;

// @brief Apply a callable to each tuple item in parallel using explicit scheduler options.
// @param T Generic value type.
// @param U Generic result type.
// @param items Tuple of input items. Type: Tuple(T...).
// @param func Callable to invoke. Type: (T) => U.
// @param options Options dictionary. Type: Dict(String, Any).
// @return A value of type Result(Tuple(U...), Tuple(Int64, String)).
let Std.Parallel.WithOptions<T, U>(items: Tuple(T...), func: (T) => U, options: Dict(String, Any)) : Result(Tuple(U...), Tuple(Int64, String))
    :: __builtin__;

// @brief Apply a callable to each tuple item in parallel for side effects.
// @param T Generic value type.
// @param U Generic result type.
// @param items Tuple of input items. Type: Tuple(T...).
// @param func Callable to invoke. Type: (T) => U.
// @return A value of type Result(Tuple(), Tuple(Int64, String)).
let Std.Parallel.ForEach<T, U>(items: Tuple(T...), func: (T) => U) : Result(Tuple(), Tuple(Int64, String)) :: __builtin__;

// @brief Fold tuple items from left to right and return the Result.
// @param T Generic value type.
// @param A Generic accumulator type.
// @param items Tuple of input items. Type: Tuple(T...).
// @param init Initial accumulator value. Type: A.
// @param func Callable to invoke. Type: (A, T) => A.
// @return A value of type Result(A, Tuple(Int64, String)).
let Std.Parallel.Reduce<T, A>(items: Tuple(T...), init: A, func: (A, T) => A) : Result(A, Tuple(Int64, String)) :: __builtin__;

// @brief Spawn a task handle for a callable and input value.
// @param T Generic value type.
// @param U Generic result type.
// @param func Callable to invoke. Type: (T) => U.
// @param value Input value. Type: T.
// @return A value of type TaskHandle.
let Std.Task.Spawn<T, U>(func: (T) => U, value: T) : TaskHandle :: __builtin__;

// @brief Wait for a task to complete and return its Result value.
// @param task Task handle value. Type: TaskHandle.
// @return A value of type Result(Any, String).
let Std.Task.Await(task: TaskHandle) : Result(Any, String) :: __builtin__;

// @brief Wait for all task handles and collect their results.
// @param tasks Tuple of task handle values. Type: Tuple(TaskHandle...).
// @return A value of type Result(Tuple(Any...), Tuple(Int64, String)).
let Std.Task.AwaitAll(tasks: Tuple(TaskHandle...)) : Result(Tuple(Any...), Tuple(Int64, String)) :: __builtin__;

// @brief Request cooperative cancellation for a task handle.
// @param task Task handle value. Type: TaskHandle.
// @return A value of type Bool.
let Std.Task.Cancel(task: TaskHandle) : Bool :: __builtin__;

// @brief Wait for a task to complete until the timeout expires.
// @param task Task handle value. Type: TaskHandle.
// @param timeout_ms Timeout in milliseconds. Type: Int64.
// @return A value of type Result(Any, String).
let Std.Task.WithTimeout(task: TaskHandle, timeout_ms: Int64) : Result(Any, String) :: __builtin__;

// @brief Apply a callable to a value.
// @param T Generic value type.
// @param U Generic result type.
// @param value Input value. Type: T.
// @param func Callable to invoke. Type: (T) => U.
// @return A value of type U.
let Std.Apply<T, U>(value: T, func: (T) => U) : U :: __builtin__;

// @brief Apply one of two callables based on a Bool condition.
// @param T Generic value type.
// @param condition Boolean condition to evaluate. Type: Bool.
// @param value Input value. Type: T.
// @param true_func Callable used when condition is true. Type: (T) => T.
// @param false_func Callable used when condition is false. Type: (T) => T.
// @return A value of type T.
let Std.Branch<T>(condition: Bool, value: T, true_func: (T) => T, false_func: (T) => T) : T :: __builtin__;

// @brief Iterate a state value while a continue callable returns true.
// @param S Generic state type.
// @param state State value. Type: S.
// @param continue_func Value for parameter continue_func. Type: (S) => Bool.
// @param step_func Callable that produces the next state. Type: (S) => S.
// @return A value of type S.
let Std.Loop<S>(state: S, continue_func: (S) => Bool, step_func: (S) => S) : S :: __builtin__;

// @brief Iterate a state value with a hard iteration cap.
// @param S Generic state type.
// @param state State value. Type: S.
// @param continue_func Value for parameter continue_func. Type: (S) => Bool.
// @param step_func Callable that produces the next state. Type: (S) => S.
// @param max_iters Maximum number of iterations to execute. Type: Int64.
// @return A value of type S.
